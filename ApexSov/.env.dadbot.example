# Apex Sovereign local profile for Dad-Bot integration (in-place upgrade mode)

# Core runtime
APEX_ENV=dev
APEX_REDIS_URL=redis://localhost:6379

# Optional auth for local bring-up
APEX_OIDC_ISSUER=
APEX_OIDC_AUDIENCE=

# Keep software signing for local-first setup
APEX_KMS_KEY_ID=
APEX_KMS_REGION=
APEX_FIPS_MODE=false
APEX_KMS_DUAL_CONTROL=false

# DadBot policy/governance defaults
APEX_FAILSAFE_GOV=false
APEX_COMPLIANCE_MODE=false
APEX_TWO_PERSON_POLICY=false

# Local provider pool (Ollama primary)
# Single-line JSON for shell/env compatibility.
APEX_UPSTREAM_PROVIDERS_JSON=[{"name":"ollama-local","type":"ollama","url":"http://host.docker.internal:11434/v1/chat/completions","model_map":{"apex-qwen":"apex-qwen","gpt-4o-mini":"apex-qwen","gpt-4o":"apex-qwen"},"auth":{"type":"none"},"timeout_seconds":30,"max_retries":2}]
APEX_UI_DEFAULT_MODEL=apex-qwen

# Drift backend options
APEX_DRIFT_BACKEND=redis
QDRANT_URL=http://localhost:6333
APEX_DLP_SEMANTIC_ENABLED=false
APEX_EMBEDDING_MODEL=text-embedding-3-small

# Egress and webhooks (tighten in production)
APEX_NO_INTERNET=false
APEX_EGRESS_ALLOWLIST_REGEX=
APEX_ALERT_WEBHOOK_URL=
APEX_SIEM_WEBHOOK_URL=

# Dad-Bot should send these headers at call time:
# x-tenant-id: family-default
# x-session-id: <dadbot-session-id>
# x-device-id: dadbot-client
