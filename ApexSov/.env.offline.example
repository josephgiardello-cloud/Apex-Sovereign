# Apex offline-first profile
# Copy to .env.offline and adjust as needed.

APEX_ENV=dev
APEX_REDIS_URL=redis://127.0.0.1:6379/0
APEX_OPENAI_URL=http://127.0.0.1:11434/v1/chat/completions
APEX_DRIFT_BACKEND=redis
APEX_NO_INTERNET=true

# Keep empty for local OpenAI-compatible servers unless auth is enabled.
OPENAI_API_KEY=

# Internal model to upstream model mapping in BaseT8 defaults to gpt-4o.
# In Ollama, create/pull a matching alias or pass the local model name in requests.
