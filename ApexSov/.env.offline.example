# Apex offline-first profile
# Copy to .env.offline and adjust as needed.

APEX_ENV=dev
APEX_REDIS_URL=redis://127.0.0.1:6379/0
APEX_OPENAI_URL=http://localhost:11434/v1/chat/completions
APEX_UPSTREAM_PROVIDERS_JSON=[{"name":"ollama-local","type":"ollama","url":"http://localhost:11434/v1/chat/completions","model_map":{"apex-qwen":"apex-qwen","gpt-4o-mini":"apex-qwen","gpt-4o":"apex-qwen"},"auth":{"type":"none"}}]
APEX_DRIFT_BACKEND=redis
APEX_NO_INTERNET=true
APEX_EGRESS_ALLOWLIST_REGEX=^(localhost|127\.0\.0\.1)$
APEX_UI_DEFAULT_MODEL=apex-qwen

# Keep empty for local OpenAI-compatible servers unless auth is enabled.
OPENAI_API_KEY=

# Recommended local core: qwen2.5:7b aliased as apex-qwen.
# Run setup_ollama_qwen.ps1 or create the alias manually before startup.
